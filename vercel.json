{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/dashboard", "destination": "/index.html" },
    { "source": "/login",     "destination": "/login.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" }
      ]
    }
  ]
}